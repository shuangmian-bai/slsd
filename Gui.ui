<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1000</width>
    <height>800</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>湖南水利水电信息检索工具</string>
  </property>
  <property name="windowIcon">
   <iconset>
    <normaloff>icon/shuangmian.ico</normaloff>icon/shuangmian.ico</iconset>
